<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_winner_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#00E676"
            android:layout_marginBottom="8dp"
            android:text="Winning Decklist" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="12dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/text_winner_decklist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#E0E0E0"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp"
                android:text="No list data." />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/text_loser_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FF5252"
            android:layout_marginBottom="8dp"
            android:text="Loser's Decklist" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1A1A"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/text_loser_decklist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#B0B0B0"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp"
                android:text="No list data." />

        </LinearLayout>

    </LinearLayout>
</ScrollView>